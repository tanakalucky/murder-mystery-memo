{
  "name": "murder-mystery-memo",
  "version": "0.0.0",
  "description": "A template for building a React application with Vite",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "bun typecheck && bun run build",
    "claude:copy": "bun run scripts/copy-claude-config.ts",
    "deploy": "wrangler deploy",
    "dev": "vite",
    "format": "oxfmt .",
    "lint": "oxlint --type-aware --fix",
    "lint:ci": "oxlint --type-aware",
    "preview": "bun run build && vite preview",
    "test": "vitest --project unit & vitest --project browser",
    "typecheck": "bun tsgo -b --noEmit",
    "ui:add": "bun run scripts/shadcn-add.ts",
    "ui:organize": "bun run scripts/organize-ui.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource-variable/noto-serif-jp": "^5.2.9",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.1.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ts-pattern": "^5.9.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "playwright": "^1.58.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "8.0.1",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^2.1.0",
    "wrangler": "^4.76.0"
  }
}
